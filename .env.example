# ═══════════════════════════════════════════════════════════════
# 一天（Yi Tian）环境变量配置
# 复制此文件为 .env 并根据需要修改
# ═══════════════════════════════════════════════════════════════

# 服务器端口（默认 3000）
PORT=3000

# 运行环境：development | production | test
NODE_ENV=development

# 数据库文件路径（默认 ./data/yi-tian.db）
DB_PATH=./data/yi-tian.db

# 日志级别：debug | info | warn | error
LOG_LEVEL=info

# CORS 允许的来源（逗号分隔），* 表示全部
CORS_ORIGINS=*

# API 速率限制：每15分钟最大请求数
RATE_LIMIT_MAX=100

# 是否在首次运行时自动填充示例数据（true/false）
SEED_ON_START=true

# 前端静态文件目录（默认 ./public）
STATIC_DIR=./public

# 是否启用请求压缩（true/false）
COMPRESSION_ENABLED=true

# 备份目录（默认 ./backups）
BACKUP_DIR=./backups
