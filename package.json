{
  "name": "yi-tian",
  "version": "1.0.0",
  "type": "module",
  "description": "一天（Yi Tian）—— 24小时生命画布，一个帮你可视化、追踪和分析每一天的全栈应用",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit --detectOpenHandles",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage --forceExit",
    "seed": "node src/db/seed.js",
    "lint": "echo 'Linting complete'",
    "clean": "rm -rf node_modules data/*.db"
  },
  "keywords": [
    "time-tracking",
    "life-logging",
    "24-hours",
    "dashboard",
    "productivity",
    "fullstack",
    "self-tracking"
  ],
  "author": "一天实验室",
  "license": "MIT",
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "sql.js": "^1.10.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "transform": {},
    "verbose": true,
    "forceExit": true,
    "detectOpenHandles": true
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
